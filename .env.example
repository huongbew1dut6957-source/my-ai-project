NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_OH_MY_CV_INTERNAL_ROUTE=

# AI 模型配置（选一种方式即可）
# 方式 1：OpenAI 兼容（DeepSeek / 智谱 / 通义千问 / OpenAI 等）
AI_API_KEY=
AI_MODEL=deepseek-chat
