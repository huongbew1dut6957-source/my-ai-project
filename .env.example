# 方式 2：Anthropic Claude（也可以直接用 AI_API_KEY 填 Anthropic 的 key + AI_API_PROVIDER=anthropic）
ANTHROPIC_API_KEY=

# AI_API_PROVIDER=openai    # "openai"（默认）或 "anthropic"
